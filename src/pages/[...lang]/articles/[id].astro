---
import Header from '../../../components/Header.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('articles');
  const mainArticles = allEntries.filter(entry => entry.id.endsWith('/index') || !entry.id.includes('/'));
  const paths = [];

  mainArticles.forEach(article => {
    const cleanId = article.id.replace(/\/index$/, '');
    paths.push({ params: { lang: undefined, id: cleanId }, props: { article, lang: 'en', allEntries } });
    paths.push({ params: { lang: 'fr', id: cleanId }, props: { article, lang: 'fr', allEntries } });
    paths.push({ params: { lang: 'ar', id: cleanId }, props: { article, lang: 'ar', allEntries } });
  });

  return paths;
}

const { article, lang, allEntries } = Astro.props;
const cleanId = article.id.replace(/\/index$/, '');

let displayTitle = article.data.title;
let EntryToRender = article;

if (lang === 'en') {
  displayTitle = article.data.title_en || article.data.title;
} else if (lang === 'fr') {
  displayTitle = article.data.title_fr || displayTitle;
  const frEntry = allEntries.find(e => e.id === `${cleanId}/content_fr`);
  if (frEntry) EntryToRender = frEntry;
} else if (lang === 'ar') {
  displayTitle = article.data.title_ar || displayTitle;
  const arEntry = allEntries.find(e => e.id === `${cleanId}/content_ar`);
  if (arEntry) EntryToRender = arEntry;
}

// THE UPGRADE: We extract 'headings' alongside the Content
const { Content, headings } = await render(EntryToRender);
const isRtl = lang === 'ar';

// Filter the map to only show main sections (H2) and sub-sections (H3)
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<html lang={lang || "en"} dir={isRtl ? "rtl" : "ltr"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ONERO | {displayTitle}</title>
  </head>
  <body>
    <Header />
    <main class="container">
      
      <div class="layout-grid">
        
        <aside class="sidebar">
          <div class="toc-container">
            <h3>{lang === 'fr' ? 'Sommaire' : lang === 'ar' ? 'محتويات' : 'Table of Contents'}</h3>
            {toc.length > 0 ? (
              <ul>
                {toc.map(heading => (
                  <li class={`depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty-toc">No sections found.</p>
            )}
          </div>
        </aside>

        <article class="prose">
          <h1>{displayTitle}</h1>
          <div class="content-body">
             <Content />
          </div>
        </article>
      </div>
      
    </main>
  </body>
</html>

<style>
  :root {
    --bg-color: #0a0a0a;
    --text-main: #ededed;
    --text-muted: #888;
    --accent: #3b82f6;
    --code-bg: #111111;
  }
  
  body {
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  /* Grid Layout for Sidebar and Content */
  .layout-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Sidebar Styles */
  .toc-container {
    position: sticky;
    top: 100px; /* Stays fixed as you scroll */
    background: rgba(20, 20, 20, 0.5);
    border: 1px solid #222;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .toc-container h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    margin-top: 0;
    margin-bottom: 1rem;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
  }

  .toc-container ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-container li { margin-bottom: 0.5rem; }
  
  /* Indent H3s slightly for a hierarchy effect */
  .toc-container .depth-3 { padding-inline-start: 1rem; font-size: 0.9rem; }

  .toc-container a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    display: block;
    line-height: 1.4;
  }

  .toc-container a:hover { color: var(--text-main); }
  .empty-toc { color: #555; font-size: 0.9rem; font-style: italic; }

  /* Premium Article Typography */
  .prose h1 {
    color: var(--text-main);
    font-size: 3.5rem;
    margin-bottom: 2rem;
    margin-top: 0;
    line-height: 1.1;
  }
  
  .content-body {
    line-height: 1.8;
    font-size: 1.15rem;
    color: #cccccc;
  }
  
  /* Auto-Anchors for Headers (Needed for ToC to work) */
  .content-body :global(h2), .content-body :global(h3) { 
    color: #fff; 
    margin-top: 3.5rem; 
    margin-bottom: 1rem; 
    scroll-margin-top: 100px; /* Prevents header from hiding under sticky nav */
  }
  .content-body :global(h2) { font-size: 2rem; border-bottom: 1px solid #222; padding-bottom: 0.5rem; }
  .content-body :global(p) { margin-bottom: 1.5rem; }
  .content-body :global(strong) { color: #fff; }
  
  /* Beautiful IDE-Style Code Blocks */
  .content-body :global(code) { 
    background: #222; 
    padding: 0.2rem 0.4rem; 
    border-radius: 4px; 
    color: #ff7b72; /* GitHub dark mode string color */
    font-family: 'Courier New', Courier, monospace; 
    font-size: 0.9em;
  }
  
  .content-body :global(pre) { 
    background: var(--code-bg) !important; 
    padding: 1.5rem; 
    border-radius: 8px; 
    overflow-x: auto; 
    border: 1px solid #333; 
    margin: 2rem 0; 
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .content-body :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: 0.95rem;
  }
  
  .content-body :global(img) { 
    max-width: 100%; 
    border-radius: 8px; 
    border: 1px solid #333; 
    margin: 2.5rem 0; 
  }

  /* Responsive Fix: Stack layout on mobile phones */
  @media (max-width: 900px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }
    .toc-container {
      position: static;
      margin-bottom: 2rem;
    }
  }
</style>