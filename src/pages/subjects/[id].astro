---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
// 1. Tell Astro to generate a unique page for every subject in your database
export async function getStaticPaths() {
  const subjects = await getCollection('subjects');
  return subjects.map(subject => {
    // Force the Subject URL to be clean (removes .yaml or .json)
    const cleanSubjectId = subject.id.replace(/\.[^/.]+$/, "");
    return {
      params: { id: cleanSubjectId },
      props: { subject, cleanSubjectId },
    };
  });
}

// 2. Grab the specific subject the user just clicked on
const { subject, cleanSubjectId } = Astro.props;

// 3. Fetch all categories, but ONLY keep the ones linked to this specific subject
const allCategories = await getCollection('categories');
const subjectCategories = allCategories.filter(
  (category) => category.data.parentSubject === cleanSubjectId
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ONERO | {subject.data.title}</title>
  </head>
  <body>
    <Header />
    <main class="container">
      <nav class="breadcrumb">
        <a href="/">&larr; Return to Base</a>
      </nav>

      <header class="hero">
        <h1>{subject.data.title}</h1>
        <p>{subject.data.description || 'Select a category to explore specific transmissions.'}</p>
      </header>

      <div class="grid">
        {subjectCategories.length === 0 ? (
          <p class="empty-state">No categories established yet.</p>
        ) : (
          subjectCategories.map((category) => {
            // Force the Category URL to be clean for the next click
            const cleanCategoryId = category.id.replace(/\.[^/.]+$/, "");
            return (
              <a href={`/categories/${cleanCategoryId}`} class="card">
                <div class="card-content">
                  <h2>{category.data.title}</h2>
                  <div class="card-footer">
                    <span>View Transmissions &rarr;</span>
                  </div>
                </div>
              </a>
            );
          })
        )}
      </div>
    </main>
  </body>
</html>

<style>
  /* Base Dark Aesthetic */
  :root {
    --bg-color: #0a0a0a;
    --card-bg: #141414;
    --text-main: #ededed;
    --text-muted: #888888;
    --accent: #3b82f6; 
    --accent-glow: rgba(59, 130, 246, 0.15);
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
    padding: 0;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Navigation */
  .breadcrumb {
    margin-bottom: 3rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--text-main);
  }

  .hero h1 {
    font-size: 3rem;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.2rem;
    margin-bottom: 3rem;
  }

  /* The Grid System */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
    grid-column: 1 / -1;
  }

  /* The Cards */
  .card {
    background-color: var(--card-bg);
    border: 1px solid #222;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 10px 30px var(--accent-glow);
  }

  .card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card h2 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    line-height: 1.3;
  }

  .card-footer {
    margin-top: auto;
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
  }
</style>