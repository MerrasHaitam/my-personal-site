---
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

// 1. Ask the database for all the subjects
const allSubjects = await getCollection('subjects');
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ONERO | الرئيسية</title>
  </head>
  <body>
    <Header />
    <main class="container">
      <header class="hero">
        <h1>موقع أونيرو</h1>
        <p>تعمق في المجال</p>
      </header>

      <div class="grid">
        {allSubjects.map((subject) => {
          const cleanId = subject.id.replace(/\.[^/.]+$/, "");
          return (
            <a href={`/ar/subjects/${cleanId}`} class="card">
              <div class="card-content">
                <h2>{subject.data.title_ar || subject.data.title}</h2>
                <div class="card-footer">
                  <span>الدخول لقاعدة البيانات &larr;</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </main>
  </body>
</html>

<style>
  /* Base Dark Aesthetic to match your main site */
  :root {
    --bg-color: #0a0a0a;
    --card-bg: #141414;
    --text-main: #ededed;
    --text-muted: #888888;
    --accent: #3b82f6; 
    --accent-glow: rgba(59, 130, 246, 0.15);
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
    padding: 0;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .hero h1 {
    font-size: 3.5rem;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .card {
    background-color: var(--card-bg);
    border: 1px solid #222;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 10px 30px var(--accent-glow);
  }

  .card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card h2 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
    line-height: 1.3;
  }

  .card-footer {
    margin-top: auto;
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
  }
</style>