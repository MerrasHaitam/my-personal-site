---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Math  | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body style="background-color: #13151a; color: white; font-family: system-ui, sans-serif;">
		<Header />
		<main style="max-width: 800px; margin: auto; padding: 2rem;">
			<h1 style="color: #D4AF37;">Mathematics</h1>
			<p style="color: #a0a0a0; font-size: 1.1rem;">
				Exploring the origins of mathematical thought.
			</p>
			<hr style="border-color: #333; margin: 2rem 0;" />
			<p> future math articles will go here...</p>
		</main>
		<Footer />
	</body>
</html>