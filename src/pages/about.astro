---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body style="background-color: #13151a; color: white; font-family: system-ui, sans-serif;">
		<Header />
		<main style="max-width: 800px; margin: auto; padding: 2rem;">
			<h1 style="color: #D4AF37;">The Origin of Onero</h1>
			
			<div style="color: #a0a0a0; font-size: 1.1rem; line-height: 1.6;">
				<p>
					My name is Haitam
				</p>
				
				<p>
					engineering student
				</p>

				<h2 style="color: #D4AF37; margin-top: 2rem; font-size: 1.5rem;">Current Pursuits</h2>
				<ul style="list-style-type: square; padding-left: 1.5rem; color: #e0e0e0;">
					<li style="margin-bottom: 0.5rem;"><strong>Technology:</strong> everything related to technology</li>
					<li style="margin-bottom: 0.5rem;"><strong>Mathematics:</strong> Tracing the origins of complex mathematical thought, scientific proofs.</li>
					<li style="margin-bottom: 0.5rem;"><strong>Physics:</strong> every field of physics</li>
				</ul>
			</div>
			
			<hr style="border-color: #333; margin: 3rem 0;" />
			<!-- footer quote -->
			<p style="text-align: center; font-style: italic; color: #646464;">
				""
			</p>

		</main>
		<Footer />
	</body>
</html>