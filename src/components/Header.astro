---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav style="display: flex; justify-content: space-between; padding: 2rem; max-width: 800px; margin: auto;">
		<div style="font-weight: bold; font-size: 1.5rem; letter-spacing: 2px;">ONERO</div>
		<div style="display: flex; gap: 20px;">
			<a href="/" style="color: white; text-decoration: none; border-bottom: 2px solid #D4AF37;">Home</a>
			<a href="/math" style="color: #646464; text-decoration: none;">Math History</a>
			<a href="/tech" style="color: #646464; text-decoration: none;">Tech</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
